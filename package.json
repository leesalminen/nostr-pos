{
  "name": "nostr-pos-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/pos-pwa"
  ],
  "scripts": {
    "build": "npm run build -w apps/pos-pwa",
    "dev": "npm run dev -w apps/pos-pwa",
    "test": "npm run test -w apps/pos-pwa",
    "check": "npm run check -w apps/pos-pwa && npm run copy-check",
    "copy-check": "bash scripts/ui-copy-check.sh",
    "protocol:check": "node scripts/validate-protocol-spec.mjs",
    "relay:smoke": "node scripts/relay-smoke.mjs",
    "dart:test": "cd packages/nostr_pos && dart test",
    "dart:cli": "cd apps/nostr_pos_cli && dart run bin/nostr_pos.dart",
    "dart:cli:test": "cd apps/nostr_pos_cli && dart test",
    "audit:pwa": "cd apps/pos-pwa && npm audit --omit=dev"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "typescript": "^5.9.3",
    "ws": "^8.20.0"
  }
}
